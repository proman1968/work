# Development mode: logs extra details, never exposes secrets in HTTP responses
WORK_DEV=false

# HTTP server
WORK_HOST=localhost
WORK_PORT=8001

# STUN server (WebRTC), UDP
# WORK_STUN_PORT=3478

# HTTPS (optional)
# WORK_TLSHOST=localhost
# WORK_TLS_PORT=8443
# WORK_TLS_CERT=/path/to/cert.pem
# WORK_TLS_KEY=/path/to/key.pem

# Auth challenge lifetime (ms), default 5 minutes
# WORK_CHALLENGE_TTL_MS=300000

# Optional AI API token (genApi)
# WORK_GEN_API_TOKEN=
