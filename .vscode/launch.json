{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "WORK (prod)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/run.mjs",
            "cwd": "${workspaceFolder}",
            "env": {
                "WORK_DEV": "false"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "WORK (dev)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/run.mjs",
            "cwd": "${workspaceFolder}",
            "env": {
                "WORK_DEV": "true"
            }
        }
    ]
}
