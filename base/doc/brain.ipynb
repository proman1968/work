input.data[i * dim + token_idx] = 2;\n//             }\n\n//             let result = torus.einsum('d, de -> e', [token, this.linear]);\n//             result = result.softmax(-1);\n\n//             if(target){\n//                 let t = target[i]; // -1 == STOP\n//                 if(t === undefined)\n//                     break\n//                 let loss = result.crossEntropy(t);\n//                 losses.push(loss.get());\n//                 loss.back();\n//             }\n//             token_idx = result.multinomial(1);\n//             // token_idx = result.maxIndex();\n//             token_idx = token_idx.get();\n//             this.predicts.push(token_idx);\n//             // await tokens.read();\n//         }\n// >losses.avg();\n//         return this.predicts;\n    }\n    forward(text){\n        let hidden = this.encode(text);\n        return this.decoder_module(hidden);\n    }\n    read(){\n        let tmp_monitor = [];\n        let code;\n        while((code = this.monitor.pop())>-1){\n            if((code & 128) === 0){\n               this.monitor.push(code);\n               break; \n            }\n            tmp_monitor.push(code);\n        }\n        let result = this.text_decoder.decode(new Int8Array(this.monitor));\n        this.monitor = tmp_monitor;\n        return result;\n    }\n    encode(text){\n        let tokens = this.text_encoder.encode(text);\n        let input = this.input;\n        let cnt_size = input.shape[0];\n        let dim = this.args.d_model;\n        for(let i = 0; i<tokens.length; i++){\n            let token = tokens[i];\n            input.data[i * dim + token] = 2;\n        }\n        input.fill(0, tokens.length * dim);\n        return this.encoder_module(input);\n    }\n    update_input(input, token_idx, i){\n        let emb = this.embeddings[token_idx];\n        let idx = i * this.args.d_model;\n        input.set(emb, idx);\n        let pos = this.get_pos(i)\n        input.set(pos, idx + 8);   \n    }\n    get_pos(i){\n        let pos = this.positions[i];\n        if(!pos)\n            pos = this.positions[i] = tensor.from(i.toString(2).padStart(this.args.pos_dim, '0').split(''));\n        return pos;\n    }\n    async run(count = 1){\n        let progress = 0;\n        let result;\n        let step = 5;\n        while(!this.stop){\n            result = await this();\n            if(progress % step === 0){\n                await this.progress(progress % 100);\n            }\n            progress++;\n            if((progress % 100) === 0){\n                count--;\n                if(count === 0)\n                    break;\n                else\n                    progress = 0;\n            }\n        }\n        return result;\n    }\n}"],"metadata":{"id":"58e25e347b","hideOutput":true,"hideCode":true},"breakpoints":"","state":"","outputs":[],"time":""},{"cell_type":"code","source":["torus.USE_GPU = false\npos = new gpt.SinusoidalPositionalEncoding(256)\n>pos"],"metadata":{"id":"96b478f615","hideOutput":true,"hideCode":true},"state":"","outputs":[],"breakpoints":"","time":""},{"cell_type":"code","source":["torus.manual_seed(1);\ntorus.LEARNING_RATE = .01\ntorus.USE_GPU = false;\ntorus.USE_SCALAR_CACHE = true;\nargs = {\n    batch_size: 1,\n    d_model: 256,\n    context_size: 256,\n    layers: 1,\n    heads: 1,\n}\nbrain = new BrainFormer(args);\n\n>brain.param_count.toLocaleString()"],"metadata":{"id":"935e8cd6cc","hideOutput":true,"hideCode":true},"outputs":[{"data":{"text/plain":"<label bold onclick='_findCodeEntry(this)' style='text-decoration: underline; padding: 2px; font-size: large; margin-bottom: 4px; cursor: pointer; color: -webkit-link'>brain.param_count.toLocaleString()</label>"}},{"data":{"text/plain":"0"}}],"state":"","breakpoints":"","time":""},{"cell_type":"code","source":[">brain.embeddings"],"metadata":{"id":"72f6ff4422","hideOutput":false,"hideCode":true},"outputs":[{"data":{"text/plain":"<label bold onclick='_findCodeEntry(this)' style='text-decoration: und