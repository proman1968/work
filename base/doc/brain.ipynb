>]=?|[+\\-*/^=]|[\\p{P}\\p{S}]/gu;\r\n        } else {\r\n            pattern = /\\S+/gu; // Просто разделение по пробелам\r\n        }\r\n        \r\n        let tokens = text.match(pattern) || [];\r\n        \r\n        if (!this.options.preserveCase) {\r\n            tokens = tokens.map(token => token.toLowerCase());\r\n        }\r\n        \r\n        return tokens;\r\n    }\r\n}"],"metadata":{"id":"11f880f33a0","hideOutput":false},"outputs":[],"breakpoints":"","state":"","time":""},{"cell_type":"code","source":["UTF8Embedding = class UTF8Embedding extends nn.Module{\n    constructor(props = {}){\n        super(props, {batch_size: 256 /*400*/ /*512*/ /*768*/, word_size: 64, d_model: 8, heads: 1, layers: 1});\n        this.props.main = this;\n        this.tokenizer = new Tokenizer();\n        this.text_encoder = new TextEncoder();\n        this.text_decoder = new TextDecoder('UTF-8');\n        this.input = tensor.zeros([this.batch_size, this.word_size, 8]);\n        this.binaries = nn.List(256, (_,i)=>tensor.from(i.toString(2).padStart(8, '0').split('')));\n        this.props.max_len = this.props.content_size;\n    }\n    __init__(){\n        this.d_attantion = Math.ceil(this.d_model / this.heads);\n        this.content_size = this.word_size;\n        this.encoder_module = new gpt.Encoder(this);\n        this.decoder_layer = tensor.rand([this.word_size, this.d_model, 256]).p._label('decoder');\n    }\n    *forward(text){\n        let generator = this.encode(text);\n        for(let emb of generator){\n            let res = this.decode(emb);\n            res = res.softmax(-1);\n            res = res.maxIndex(-1); \n// >res.data           \n            yield new Promise(async resolve=>{\n                await res.read();\n                let text = [];\n                let di = res.dim_info(0);\n                let start = 0;\n                for (let i = 0; i < di.size; i++) {\n                    let word_codes = res.data.subarray(start, start + di.stride);\n                    text.push(this.text_decoder.decode(new Uint8Array(word_codes)));\n                    start += di.stride;\n                }\n                resolve(text);\n            })\n        }\n    }\n    train(text){\n        let emb_batch;\n        if(!text){\n            let words_codes = [];\n            for(let t = 0; t<this.batch_size; t++){\n                let size = Math.trunc(torus.generator() * this.word_size) + 1;\n                let word = Array(this.word_size).fill(0);\n                for(let p = 0; p<size; p++){\n                    let code = Math.trunc(torus.generator() * 255) + 1;\n                    word[p] = code;\n                }\n                words_codes.push(word);\n            }\n            emb_batch = this.run_encode(words_codes);\n        }\n        else{\n            emb_batch = this.encode(text);\n        }\n\n        let res;\n        for(let emb of emb_batch){\n            res = this.decode(emb);\n            res = res.softmax(-1);\n            res = res.crossEntropy(this.target);\n            res.back();\n        }\n        return res;\n    }\n    encode(text){\n        let words = this.tokenizer.tokenize(text);\n        let words_codes = words.map(t=>{\n            let word = new torus.DEFAULT_TYPE(this.word_size);\n            word.set(this.text_encoder.encode(t).subarray(0, this.word_size));\n            return word;\n        });\n// >words_codes.toString()        \n        return this.run_encode(words_codes);\n    }\n    *run_encode(words_codes){\n        this.target = [...words_codes];\n        \n        while(words_codes.length){\n            let words_batch = words_codes.splice(0, this.batch_size);\n            this.input.data.fill(0);\n            for(let w = 0; w<words_batch.length; w++){\n                let word = words_batch[w];\n                let word_offset =  w * this.word_size * 8;\n                for(let t = 0; t<this.word_size; t++){\n                    let idx = word[t];\n                    if(!idx)\n                        break;\n                    let emb = this.binaries[idx];\n                    let offset = word_offset + t * 8; \n                    this.input.data.set(emb.data, offset);\n                }\n            }             \n            this.input.writeToGPU(true);\n            let result = this.encoder_module(this.input);\n            yield result\n        }\n    }\n    decode(emb_batch){\n        let result = torus.einsum('.ld, lde->.le', [emb_batch, this.decoder_layer]);\n        return result;\n    }\n}"],"metadata":{"id":"ad18418cab","hideOutput":false},"breakpoints":"","outputs":[],"state":"","time":""},{"cell_type":"code","source":["torus.USE_GPU = true;\ntorus.manual_seed(1);\nemb = new UTF8Embedding();\nreal_count = 0"],"metadata":{"id":"160fa52110b","hideOutput":false},"outputs":[],"state":"","breakpoints":"","time":""},{"cell_type":"code","source":["torus.LEARNING_RATE = 0.0008 /*0.000602*/ /*0.0005*/ /*0.00028*/\n\n//TRAIN\nlet lern_count = 100;\nloss = ''\nfor(let i = 0; i < lern_count; i++){\n    loss = emb.train();\n    real_count++;\n    if (i % 5 === 0) {\n        await this.setProgress(Math.round(i / lern_count * 100));\n    }\n}\n// >loss.data\n// >loss.data.findIndex(e=>Number.isNaN(e))\nloss = loss.mean(-1);\nawait loss.read();\n>loss\nloss = loss.mean(-1);\nawait loss.read();\n>loss\n//INFERENCE\ncontent = 'всем желаю много лет жизни, счастья и здоровья'   //русский\nres = emb(content)\ntext = ''\nfor (let val of res){\n    val = await val;\n    for (let word of val)\n        text += word + ' ';\n}\n>text.trim()\n\n// >emb.decoder_layer\n>real_count\n>tensor._id"],"metadata":{"id":"5590a91fd6","hideOutput":false},"state":"","outputs":[{"data":{"text/plain":"<label bold onclick='_findCodeEntry(this)' style='text-decoration: underline; padding: 2px; font-size: large; margin-bottom: 4px; cursor: pointer; color: -webkit-link'>loss</label>"}},{"data":{"text/plain":" GPU  (id#654): vector mean: shape(256), length(256), Float3